<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.user.homarr-disk-space</string>
	<key>WorkingDirectory</key>
	<string>/ABSOLUTE/PATH/TO/homarr-disk-space</string>
	<key>ProgramArguments</key>
	<array>
		<string>/ABSOLUTE/PATH/TO/node</string>
		<string>/ABSOLUTE/PATH/TO/homarr-disk-space/scripts/supervised-start.mjs</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/ABSOLUTE/PATH/TO/homarr-disk-space/logs/launchd.out.log</string>
	<key>StandardErrorPath</key>
	<string>/ABSOLUTE/PATH/TO/homarr-disk-space/logs/launchd.err.log</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>NODE_ENV</key>
		<string>production</string>
	</dict>
</dict>
</plist>
